{
  "name": "hrms-lite-api",
  "version": "1.0.0",
  "description": "HRMS Lite REST API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop hrms-lite-api",
    "pm2:restart": "pm2 restart hrms-lite-api --env production",
    "pm2:logs": "pm2 logs hrms-lite-api",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "pm2": "^6.0.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
